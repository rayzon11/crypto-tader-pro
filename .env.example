# .env.example — Copy to .env and fill in your real keys

# Exchange API Keys
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET=your_coinbase_secret_here
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here

# On-chain & Data
ETHERSCAN_API_KEY=your_etherscan_api_key
INFURA_URL=https://mainnet.infura.io/v3/your_project_id
GLASSNODE_API_KEY=your_glassnode_api_key

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Infrastructure
POSTGRES_PASSWORD=strong_random_password_here
REDIS_URL=redis://localhost:6379

# Risk Limits
MAX_DRAWDOWN_PCT=0.05
MAX_POSITION_PCT=0.20
DAILY_LOSS_LIMIT_USDT=500
MAX_OPEN_POSITIONS=5

# News Agent
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# Trading
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,AVAX/USDT
PAPER_TRADING=true
